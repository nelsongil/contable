<?php
// Template for database configuration - RENAME TO database.php and fill in values
// Installed: [domain] · [host]

define('APP_VERSION', '1.2');

define('DB_HOST',    'localhost');
define('DB_NAME',    'your_db_name');
define('DB_USER',    'your_db_user');
define('DB_PASS',    'your_db_password');
define('DB_CHARSET', 'utf8mb4');
define('SECRET_KEY', 'your_generated_secret_key');

define('EMPRESA_NOMBRE',   'Your Company Name');
define('EMPRESA_SOCIEDAD', 'Legal Entity Name');
define('EMPRESA_CIF',      'CIF/NIF');
define('EMPRESA_DIR1',     'Address Line 1');
define('EMPRESA_DIR2',     'Address Line 2');
define('EMPRESA_TEL',      'Telephone');
define('EMPRESA_EMAIL',    'Email');
define('EMPRESA_WEB',      'Website');
define('EMPRESA_BANCO',    'Bank Name');
define('EMPRESA_IBAN',     'IBAN');
define('EMPRESA_IVA',      0.21);
define('EMPRESA_IRPF',     0.15);

function getDB(): PDO {
    static $pdo = null;
    if ($pdo === null) {
        $dsn = 'mysql:host=' . DB_HOST . ';dbname=' . DB_NAME . ';charset=' . DB_CHARSET;
        $pdo = new PDO($dsn, DB_USER, DB_PASS, [
            PDO::ATTR_ERRMODE            => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_DEFAULT_FETCH_MODE => PDO::FETCH_ASSOC,
            PDO::ATTR_EMULATE_PREPARES   => false,
        ]);
    }
    return $pdo;
}
